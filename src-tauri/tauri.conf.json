{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Yee Music",
  "version": "0.1.5",
  "identifier": "com.isen.yee-music",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Yee Music",
        "width": 1440,
        "height": 900,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "windowEffects": {
          "effects": ["acrylic", "mica"]
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
