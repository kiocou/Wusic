{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Wusic",
  "version": "0.3.1",
  "identifier": "com.kiocou.wusic",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Wusic",
        "width": 1440,
        "height": 900,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "windowEffects": {
          "effects": ["acrylic", "mica"]
        },
        "additionalBrowserArgs": "--disk-cache-size=104857600 --js-flags=--max-old-space-size=2048 --enable-gpu-rasterization --enable-zero-copy --enable-hardware-overlays=single-fullscreen,single-on-top,underlay --enable-features=VaapiVideoDecoder,VaapiVideoEncoder,AngleGLES,UseSkiaRenderer --ignore-gpu-blocklist --enable-gpu --disable-backgrounding-occluded-windows --disable-renderer-backgrounding"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": "v1Compatible",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "icons/prev.png": "icons/prev.png",
      "icons/play.png": "icons/play.png",
      "icons/pause.png": "icons/pause.png",
      "icons/next.png": "icons/next.png"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU5MTJFQjhERTYwNkZENDEKUldSQi9RYm1qZXNTNlVzUHBidEhhcDhuS2xFNExocTk0Y0Fldk1lb1RlaGlQNHB0S2VxVnVsaUcK",
      "active": true,
      "endpoints": [
        "https://github.com/kiocou/Wusic/releases/download/updater/update.json"
      ]
    }
  }
}
